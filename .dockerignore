# === Docker build context を大幅削減 ===

# 最も重要な除外（これだけで効果大）
node_modules/
.git/
.gitignore
.gitmodules
.github/

# 開発・テスト関連
dist/
build/
coverage/
.cache/
tmp/
*.test.ts
*.spec.ts
jest.config.js

# データ・ログファイル
*.log
*.csv
*.jsonl
*.sqlite
*.db
data/
vendor/

# ドキュメント類
README*.md
LICENSE
docs/

# その他不要
.env
.env.example
*.DS_Store
